# ──────────────────────────────────────────────────────────────────────────────
# Production Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
DOMAIN=canari-emse.fr
ALLOW_ORIGIN=https://canari-emse.fr

# ── Docker Registry ───────────────────────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_PREFIX=emse-students/canari
TAG=latest

# ── Security ──────────────────────────────────────────────────────────────────
# ⚠️ CRITICAL: This MUST match frontend VITE_JWT_SECRET for token validation!
# Generate with: openssl rand -hex 32
# MUST be 64-char hex string for HS256 HMAC signature
JWT_SECRET=your-secret-jwt-key-here-change-me

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=auth_db

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=chat_gateway=info,tower_http=info
NODE_ENV=production

# ── Ports (for development override only) ─────────────────────────────────────
# Ces ports sont utilisés par docker-compose pour exposer les services
# En production derrière Nginx, ces services ne sont pas exposés publiquement
# Nginx écoute sur 80/443 et proxy les requêtes vers ces ports en interne
GATEWAY_PORT=3000
DELIVERY_PORT=3001
