# ──────────────────────────────────────────────────────────────────────────────
# Production Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
DOMAIN=canari-emse.fr
ALLOW_ORIGIN=https://canari-emse.fr

# ── Docker Registry ───────────────────────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_PREFIX=your-github-org/canari
TAG=latest

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-jwt-key-here-change-me

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=auth_db

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=chat_gateway=info,tower_http=info
NODE_ENV=production

# ── Ports (for development override only) ─────────────────────────────────────
GATEWAY_PORT=3000
DELIVERY_PORT=3001
