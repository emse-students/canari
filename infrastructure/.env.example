# ──────────────────────────────────────────────────────────────────────────────
# Production Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
DOMAIN=canari-emse.fr
ALLOW_ORIGIN=https://canari-emse.fr

# ── Docker Registry ───────────────────────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_PREFIX=emse-students/canari
TAG=latest

# ── Security ──────────────────────────────────────────────────────────────────
# ⚠️ CRITICAL: This MUST match frontend VITE_JWT_SECRET for token validation!
# Generate with: openssl rand -hex 32
# MUST be 64-char hex string for HS256 HMAC signature
JWT_SECRET=your-secret-jwt-key-here-change-me

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=auth_db

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=chat_gateway=info,tower_http=info
NODE_ENV=production

# ── Ports ──────────────────────────────────────────────────────────────────────
# Port hôte du frontend Docker (cloudflared peut pointer vers localhost:8080)
FRONTEND_HOST_PORT=8080

# Ports internes des services backend
GATEWAY_PORT=3000
DELIVERY_PORT=3001
