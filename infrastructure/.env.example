# ──────────────────────────────────────────────────────────────────────────────
# Production Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
DOMAIN=canari-emse.fr
# chat-gateway CORS (WebSocket /api/ws, /api/presence). Use * for dev, or a comma-separated
# list so local Vite matches the browser Origin, e.g.:
#   ALLOW_ORIGIN=https://canari-emse.fr,http://localhost:1420
ALLOW_ORIGIN=https://canari-emse.fr

# Public SPA origin - sans slash final. Utilisée par tous les Nest (CORS acceptés,
# dont chat-delivery pin-check si le client les appelle hors même origine) et cookies auth.
# Le workflow CD définit automatiquement FRONTEND_URL dans infrastructure/.env
# depuis le secret GitHub BASE_URL (= URL publique du site).
FRONTEND_URL=https://canari-emse.fr

# Contrôle général NODE.js (production par défaut via compose).
# NODE_ENV=production

# ── Docker Registry ───────────────────────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_PREFIX=emse-students/canari
TAG=latest

# ── Security ──────────────────────────────────────────────────────────────────
# Utilisé par : chat-gateway (validation des tokens WebSocket)
# En prod, doit correspondre au GitHub Secret JWT_SECRET (injecté au build CI)
# Générer avec : openssl rand -hex 32
JWT_SECRET=your-secret-jwt-key-here-change-me

# Secret partagé entre social-service et chat-delivery-service pour les appels push internes.
# Doit correspondre dans les deux services. Générer avec : openssl rand -hex 32
INTERNAL_SECRET=your-internal-secret-here-change-me

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=auth_db

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=chat_gateway=info,tower_http=info
NODE_ENV=production

# ── Ports ──────────────────────────────────────────────────────────────────────
# Port hôte du frontend Docker (cloudflared peut pointer vers localhost:8080)
FRONTEND_HOST_PORT=8080

# Ports internes des services backend
GATEWAY_PORT=3000
DELIVERY_PORT=3001

# ── Media Service / MinIO ───────────────────────────────────────────────────
# Générer avec : openssl rand -hex 8
MINIO_ROOT_USER=
# Générer avec : openssl rand -base64 24
MINIO_ROOT_PASSWORD=
# Ports hôte pour éviter les conflits locaux (conteneur reste sur 9000/9001)
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# Si vides, héritent de MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=canari-media
MEDIA_MAX_SIZE_MB=50

# ── User Avatar Service ──────────────────────────────────────────────────────
# API externe pour la gestion des photos de profil (obligatoire)
AVATAR_API_URL=https://gallery.mitv.fr
AVATAR_API_KEY=

# ── Authentik OIDC ───────────────────────────────────────────────────────────
# URL de base de l'instance Authentik (sans slash final)
AUTHENTIK_BASE_URL=https://auth.example.com
# Client ID et Secret du Provider OAuth2/OIDC Authentik (type Confidential)
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# ── Push Notifications Android (FCM) ────────────────────────────────────────
# JSON du compte de service Firebase Admin SDK (obligatoire pour le push Android).
# Générer depuis : console.firebase.google.com → Paramètres projet → Comptes de service → Générer une nouvelle clé privée
# Coller le contenu JSON sur une seule ligne (ou utiliser un secret dans votre CI/CD).
# Sans cette variable, toutes les notifications push Android sont désactivées silencieusement.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── WebRTC / Cloudflare Calls TURN (required for voice/video calls) ───────────
# API token (GitHub secret CLOUDFLARE_CALLS_API_TOKEN) - never expose to the browser.
# GET /api/calls/ice-servers returns 503 if either value below is missing.
CLOUDFLARE_CALLS_API_TOKEN=
# TURN key ID from Cloudflare Dashboard → Realtime → TURN
CLOUDFLARE_TURN_KEY_ID=
# Credential TTL in seconds (default 7200 = 2 hours)
CLOUDFLARE_TURN_TTL_SECONDS=7200
# Optional: TURN for call-service SFU container only (not used by ice-servers API)
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ── Dev Routes ───────────────────────────────────────────────────────────────
# Active des routes de développement sensibles (ex: dev-login).
# Laisser à false sauf besoin explicite en environnement local contrôlé.
ENABLE_DEV_ROUTES=false
