# ──────────────────────────────────────────────────────────────────────────────
# Variables de la stack Authentik (projet "miconnect")
# Copier vers /home/canari/miconnect/.env (la CD le fait depuis les secrets GitHub)
# ──────────────────────────────────────────────────────────────────────────────

# Mot de passe PostgreSQL Authentik. Secret GitHub: MICONNECT_PG_PASS
# Generer avec : openssl rand -hex 24
PG_PASS=

# Cle secrete Authentik (signatures de session/tokens). Secret GitHub: MICONNECT_AUTHENTIK_SECRET_KEY
# Generer avec : openssl rand -base64 60
AUTHENTIK_SECRET_KEY=

# Non-secrets (valeurs par defaut du compose, surchargeables si besoin)
# PG_DB=authentik
# PG_USER=authentik
# AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
# AUTHENTIK_TAG=2026.2.2
# COMPOSE_PORT_HTTP=9000
# COMPOSE_PORT_HTTPS=9443
