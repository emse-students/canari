{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "jsxSingleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "proseWrap": "preserve",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "svelte": true,
  "ignorePatterns": [
    "**/node_modules/**",
    "**/build/**",
    "**/dist/**",
    "**/.svelte-kit/**",
    "**/.tauri/**",
    "**/coverage/**",
    "**/target/**",
    "**/.gradle/**",
    "**/.kotlin/**",
    "**/src/lib/proto/**",
    "**/src/lib/wasm/**",
    "**/src/lib/paraglide/**",
    "**/project.inlang/**",
    "**/src-tauri/gen/**",
    "**/src-tauri/patches/**",
    "**/src-tauri/tauri.conf.json",
    "**/*.tsbuildinfo",
    "**/.env",
    "**/.env.local",
    "**/bun.lock",
    "**/package-lock.json"
  ]
}
