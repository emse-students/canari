{
  "name": "@canari/shared-ts",
  "version": "0.10.6",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "oxlint -c ../../.oxlintrc.nest.json src",
    "lint:fix": "oxlint -c ../../.oxlintrc.nest.json --fix src",
    "format": "oxfmt -c ../../oxfmt.json --write \"src/**/*.ts\"",
    "format:check": "oxfmt -c ../../oxfmt.json --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^7.0.2001",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "base64-js": "^1.5.1"
  }
}
