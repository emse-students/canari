#!/bin/sh
# Pre-push hook for Canari project
# Prevent pushing dirty worktrees and run checks only for impacted projects

[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"
export PATH="$HOME/.cargo/bin:$PATH"

if ! git diff --cached --quiet; then
  echo "❌ Push bloqué : des fichiers sont stagés mais pas commités."
  echo "   Committez ou stashez avant de pusher."
  exit 1
fi

# `|| true` : sans upstream (push -u d'une branche neuve) git rev-parse sort en 128.
# Le wrapper husky exécute ce hook sous `sh -e`, donc une substitution qui échoue
# tuerait le script avant tout check. On retombe alors sur le diff-tree de HEAD.
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || true)
if [ -n "$UPSTREAM" ]; then
  CHANGED_FILES=$(git diff --name-only "$UPSTREAM"...HEAD)
else
  CHANGED_FILES=$(git diff-tree --no-commit-id --name-only -r HEAD)
fi

if [ -z "$CHANGED_FILES" ]; then
  exit 0
fi

echo "$CHANGED_FILES" | grep -Eq '^(\.github/workflows/|\.husky/|Makefile|libs/shared-ts/|libs/shared-rust/)' && RUN_ALL=1 || RUN_ALL=0
echo "$CHANGED_FILES" | grep -Eq '^frontend/' && RUN_FRONTEND=1 || RUN_FRONTEND=0
echo "$CHANGED_FILES" | grep -Eq '^apps/chat-delivery-service/' && RUN_DELIVERY=1 || RUN_DELIVERY=0
echo "$CHANGED_FILES" | grep -Eq '^apps/chat-gateway/' && RUN_GATEWAY=1 || RUN_GATEWAY=0
echo "$CHANGED_FILES" | grep -Eq '^frontend/mls-core/' && RUN_MLS_CORE=1 || RUN_MLS_CORE=0
echo "$CHANGED_FILES" | grep -Eq '^frontend/mls-wasm/' && RUN_MLS_WASM=1 || RUN_MLS_WASM=0
echo "$CHANGED_FILES" | grep -Eq '^frontend/src-tauri/' && RUN_TAURI=1 || RUN_TAURI=0

if [ "$RUN_ALL" -eq 1 ]; then
  RUN_FRONTEND=1
  RUN_DELIVERY=1
  RUN_GATEWAY=1
  RUN_MLS_CORE=1
  RUN_MLS_WASM=1
  RUN_TAURI=1
fi

if [ "$RUN_FRONTEND" -eq 1 ]; then
  (
    cd frontend && bun run lint && bun run check && bun run format:check
  ) || {
    echo "❌ Frontend checks failed (oxlint/oxvelte/check/format:check)."
    exit 1
  }
fi

if [ "$RUN_DELIVERY" -eq 1 ]; then
  (
    cd apps/chat-delivery-service && npm run lint && npm run format:check && npm test
  ) || {
    echo "❌ chat-delivery-service checks failed (oxlint/format:check/test)."
    exit 1
  }
fi

if [ "$RUN_GATEWAY" -eq 1 ]; then
  (
    cd apps/chat-gateway && cargo fmt -- --check && cargo clippy --all-targets --all-features -- -D warnings
  ) || {
    echo "❌ chat-gateway checks failed (fmt/clippy)."
    exit 1
  }
fi

# Crates Rust sous frontend/ : miroir strict de la CI avant push.
if [ "$RUN_MLS_CORE" -eq 1 ]; then
  (
    cd frontend/mls-core && cargo fmt -- --check && cargo clippy --all-targets -- -D warnings
  ) || {
    echo "❌ mls-core checks failed (fmt/clippy)."
    exit 1
  }
fi

# mls-wasm : fmt + BUILD REEL pour la cible wasm32 (miroir du `wasm-pack build` de la CI). Le
# clippy host ne couvre PAS les erreurs specifiques a wasm32 (feature getrandom/js, codegen) ;
# sans ce build, une casse WASM n'apparaissait qu'en CD. On la rattrape maintenant au pre-push.
# Un changement de mls-core (dependance de mls-wasm) declenche aussi ce build.
if [ "$RUN_MLS_WASM" -eq 1 ] || [ "$RUN_MLS_CORE" -eq 1 ]; then
  (
    cd frontend/mls-wasm || exit 1
    cargo fmt -- --check || exit 1
    if ! rustup target list --installed 2>/dev/null | grep -q '^wasm32-unknown-unknown$'; then
      echo "⚠️  Cible wasm32-unknown-unknown absente - requise pour verifier le build WASM."
      echo "   Installez-la : rustup target add wasm32-unknown-unknown"
      exit 1
    fi
    cargo build --target wasm32-unknown-unknown --quiet || exit 1
  ) || {
    echo "❌ mls-wasm checks failed (fmt / build wasm32 - miroir du wasm-pack CI)."
    exit 1
  }
fi

if [ "$RUN_TAURI" -eq 1 ]; then
  # fmt --check seul : clippy de src-tauri compile toute l'app + deps = trop lourd pour un hook.
  (cd frontend/src-tauri && cargo fmt -- --check) || {
    echo "❌ src-tauri fmt check failed."
    exit 1
  }
fi

exit 0
