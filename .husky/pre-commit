#!/bin/sh
# Pre-commit hook — auto-fixe et re-stage plutôt que de bloquer.

STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "$STAGED_FILES" | grep -Eq '^(\.github/workflows/|\.husky/|Makefile|libs/shared-ts/|libs/shared-rust/)' && RUN_ALL=1 || RUN_ALL=0
echo "$STAGED_FILES" | grep -Eq '^frontend/' && RUN_FRONTEND=1 || RUN_FRONTEND=0
echo "$STAGED_FILES" | grep -Eq '^apps/chat-delivery-service/' && RUN_DELIVERY=1 || RUN_DELIVERY=0
echo "$STAGED_FILES" | grep -Eq '^apps/chat-gateway/' && RUN_GATEWAY=1 || RUN_GATEWAY=0

if [ "$RUN_ALL" -eq 1 ]; then
  RUN_FRONTEND=1
  RUN_DELIVERY=1
  RUN_GATEWAY=1
fi

if [ "$RUN_FRONTEND" -eq 1 ]; then
  (cd frontend && bun run lint:fix -- --no-cache && bun run format) || {
    echo "❌ Frontend lint/format échoué."
    exit 1
  }
  git diff --name-only -- frontend/ | xargs -r git add
  (cd frontend && npx svelte-check --tsconfig ./tsconfig.json --threshold warning) || {
    echo "❌ Frontend svelte-check échoué."
    exit 1
  }
fi

if [ "$RUN_DELIVERY" -eq 1 ]; then
  (cd apps/chat-delivery-service && npm run lint) || {
    echo "❌ chat-delivery-service lint échoué."
    exit 1
  }
  git diff --name-only -- apps/chat-delivery-service/ | xargs -r git add
fi

if [ "$RUN_GATEWAY" -eq 1 ]; then
  (cd apps/chat-gateway && cargo fmt) || {
    echo "❌ chat-gateway cargo fmt échoué."
    exit 1
  }
  git diff --name-only -- apps/chat-gateway/ | xargs -r git add
fi

exit 0
