# Load nvm so node/npx/npm are available in non-interactive shells
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh" --no-use

# Also ensure bun is on PATH
export PATH="$HOME/.bun/bin:$PATH"

cd frontend

# 1. Auto-format then re-stage so CI prettier --check always passes
npm run format
git add -u .

# 2. Lint (fails on unfixable ESLint errors)
npm run lint

# 3. Type-check + Svelte diagnostics
npx svelte-check --tsconfig ./tsconfig.json --threshold warning
