{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["../.oxlintrc.json"],
  "plugins": ["typescript", "import", "unicorn"],
  "env": {
    "browser": true,
    "node": true,
    "svelte": true
  },
  "ignorePatterns": [
    "build/**",
    "dist/**",
    ".svelte-kit/**",
    "node_modules/**",
    "src/lib/proto/**",
    "src/lib/wasm/**",
    "src/lib/paraglide/**"
  ],
  "rules": {
    "typescript/no-explicit-any": "off",
    "typescript/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "eslint/no-unassigned-vars": "off",
    "import/default": "off"
  }
}
