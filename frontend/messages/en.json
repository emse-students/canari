  "admin_status_ws_connected_label": "Connected",
  "admin_status_title": "Live connections",
  "admin_status_subtitle": "{count} device(s) - refreshing every {sec}s",
  "admin_status_last_updated_label": "Updated {time}",
  "admin_status_legend_button": "Legend",
  "admin_status_refresh_button": "Refresh",
  "admin_status_legend_heading": "How to read this table",
  "admin_status_legend_ws_label": "WS (WebSocket)",
  "admin_status_legend_ws_html": "Active WebSocket connection in the gateway's memory. Each tab open in the app counts as a tab (the \"Tabs\" column). After a <strong class=\"text-text-main\">forced stop</strong> of the app, the server sends a Ping every 30s: if it doesn't receive a Pong, it closes the connection. The user stays marked \"WS connected\" for <strong class=\"text-text-main\">up to ~30s</strong> after disconnecting.",
  "admin_status_legend_redis_label": "Redis (presence)",
  "admin_status_legend_redis_html": "Key <code class=\"rounded bg-[var(--surface-elevated)] px-1 font-mono text-xs\">user:online:&#123;userId&#125;:&#123;deviceId&#125;</code> in Redis. Created on WS connection, refreshed on every Pong. Automatically removed when the connection closes cleanly.",
  "admin_status_legend_ttl_label": "TTL (seconds remaining)",
  "admin_status_legend_ttl_html": "Remaining lifetime of the Redis key. The key expires after 90s without a refresh. <span class=\"text-green-ok font-medium\">Green</span> = healthy, <span class=\"text-cn-yellow font-medium\">yellow</span> = expiring soon, <span class=\"text-red-err font-medium\">red</span> = &lt;20s (connection probably dead).",
  "admin_status_legend_anomalies_label": "Anomalies (yellow background)",
  "admin_status_legend_anomalies_html": "<strong class=\"text-text-main\">Redis ✓ but WS -</strong>: connection closed (e.g. forced app stop) but the Redis key hasn't expired yet. Will disappear within ≤30s.<br /><strong class=\"text-text-main\">WS ✓ but Redis -</strong>: active connection but presence never written (gateway bug) or TTL expired without refresh.",
  "admin_status_no_devices": "No devices.",
  "admin_status_anomalies_heading": "{count} anomaly(ies) - WS and Redis out of sync",
  "admin_status_anomalies_desc": "Yellow background = WS and Redis disagree on the device's status.",
  "admin_status_no_anomalies": "No anomalies - WS and Redis are in sync on all devices",
  "admin_status_all_devices_heading": "All devices ({count})",

