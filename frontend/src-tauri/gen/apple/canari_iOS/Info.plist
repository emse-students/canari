<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.10.3</string>
	<key>CFBundleVersion</key>
	<string>0.10.3</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>processing</string>
		<string>fetch</string>
	</array>
	<!-- BGTaskScheduler identifiers the app may submit. Must list every identifier passed to
	     registerForTaskWithIdentifier: / submitTaskRequest: or BGTaskScheduler throws. This
	     BGProcessingTask is the iOS analogue of Android's expedited MlsBackgroundWorker: it
	     drains mls_pending.db (canari_native_cleanup_pending_db) when the OS grants a
	     background-processing window. Note: iOS never wakes a force-quit app, so a user who
	     swipes the app away receives no silent data pushes and no BGTask runs until relaunch. -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>fr.emse.canari.cleanup</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
		<string>metal</string>
	</array>
	<key>UIStatusBarHidden</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string></string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<!-- Custom URL scheme registration for tauri-plugin-deep-link custom-scheme links
	     (OIDC callback fr.emse.canari://callback, Stripe return, chat/post/form routing).
	     On Android the plugin generates the intent-filter into AndroidManifest.xml at build
	     time; on iOS the CFBundleURLTypes entry must be declared here manually or the OS
	     never hands the URL back to the app - which would break Authentik OIDC login. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>fr.emse.canari</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>fr.emse.canari</string>
			</array>
		</dict>
	</array>
	<!-- Supported localizations for the Info.plist usage strings. iOS resolves the device
	     language against this list and loads the matching <lang>.lproj/InfoPlist.strings
	     (fr/en); an unsupported language falls back to the base values below (French, the
	     app's development region). Keep in sync with the canari_iOS/*.lproj folders. -->
	<key>CFBundleLocalizations</key>
	<array>
		<string>fr</string>
		<string>en</string>
	</array>
	<!-- Privacy usage strings: iOS hard-crashes on first access to a protected resource
	     when its *UsageDescription key is absent. Face ID in particular crashes the biometric
	     unlock flow without NSFaceIDUsageDescription. These base values are French (app is
	     French-first) and act as the fallback; per-locale overrides live in
	     canari_iOS/{fr,en}.lproj/InfoPlist.strings (WP-iOS-10). -->
	<key>NSCameraUsageDescription</key>
	<string>Canari utilise l'appareil photo pour prendre des photos et vidéos à partager dans vos conversations.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Canari utilise le microphone pour enregistrer des messages vocaux et passer des appels.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Canari accède à vos photos pour les partager dans vos conversations.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Canari utilise Face ID pour déverrouiller l'application de façon sécurisée.</string>
	<!-- The APNs<->FCM token bridge relies on Firebase's App Delegate Proxy swizzling
	     (main.mm deliberately defines no UIApplicationDelegate). Setting this explicitly to
	     YES makes the dependency intentional instead of relying on the framework default. -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<true/>
</dict>
</plist>
