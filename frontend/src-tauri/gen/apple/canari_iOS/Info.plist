<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.9.9</string>
	<key>CFBundleVersion</key>
	<string>0.9.9</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>processing</string>
		<string>fetch</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
		<string>metal</string>
	</array>
	<key>UIStatusBarHidden</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string></string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<!-- Privacy usage strings: iOS hard-crashes on first access to a protected resource
	     when its *UsageDescription key is absent. Face ID in particular crashes the biometric
	     unlock flow without NSFaceIDUsageDescription. French copy (app is French-first);
	     proper per-locale InfoPlist.strings is a follow-up (see CLAUDE.md iOS WP). -->
	<key>NSCameraUsageDescription</key>
	<string>Canari utilise l'appareil photo pour prendre des photos et vidéos à partager dans vos conversations.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Canari utilise le microphone pour enregistrer des messages vocaux et passer des appels.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Canari accède à vos photos pour les partager dans vos conversations.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Canari utilise Face ID pour déverrouiller l'application de façon sécurisée.</string>
	<!-- The APNs<->FCM token bridge relies on Firebase's App Delegate Proxy swizzling
	     (main.mm deliberately defines no UIApplicationDelegate). Setting this explicitly to
	     YES makes the dependency intentional instead of relying on the framework default. -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<true/>
</dict>
</plist>