# Uncomment the next line to define a global platform for your project

target 'canari_iOS' do
platform :ios, '14.0'
  # Firebase (FirebaseCore + FirebaseMessaging) is provided via Swift Package
  # Manager - see the XCRemoteSwiftPackageReference "firebase-ios-sdk" and the
  # target's packageProductDependencies in canari.xcodeproj. Do NOT also declare
  # it as a CocoaPod here: two dependency managers linking the same Firebase
  # frameworks causes duplicate-symbol link errors.
end

target 'canari_macOS' do
platform :osx, '11.0'
  # Pods for canari_macOS
end

# Delete the deployment target for iOS and macOS, causing it to be inherited from the Podfile
post_install do |installer|
 installer.pods_project.targets.each do |target|
  target.build_configurations.each do |config|
   config.build_settings.delete 'IPHONEOS_DEPLOYMENT_TARGET'
   config.build_settings.delete 'MACOSX_DEPLOYMENT_TARGET'
  end
 end
end
