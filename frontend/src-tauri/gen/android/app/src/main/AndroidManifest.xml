<?xml version="1.0" encoding="utf-8"?>
<!--
  ⚠️  CE MANIFEST EST CUSTOM — NE PAS LE LAISSER ÉCRASER PAR `tauri android init`.
  `tauri android build`/`dev` ne touchent que la section deep-link (marqueurs
  AUTO-GENERATED). Mais `tauri android init` / `tauri migrate` / une MAJ majeure de
  Tauri régénèrent gen/android depuis le template et EFFACENT tout ce qui suit.
  Si ça arrive (cf. régression 53e659a0), RESTAURER impérativement :
    - <application android:name=".CanariApplication">  (init channels, push secret)
    - <service .CanariFirebaseMessagingService> + intent-filter MESSAGING_EVENT
      (SANS lui, Firebase n'appelle jamais onMessageReceived → aucune notif app tuée)
    - permissions push : POST_NOTIFICATIONS, WAKE_LOCK, c2dm RECEIVE, RECEIVE_BOOT_COMPLETED
    - <receiver .CanariBootReceiver> (BOOT_COMPLETED/MY_PACKAGE_REPLACED, WP-XP-4)
    - <receiver .CanariNotificationActionReceiver> (quick actions, WP-XP-1)
    - retrait AD_ID, networkSecurityConfig, allowBackup=false (+ tools:replace)
  NE PAS remettre android:debuggable (placeholder ${debuggable} non défini dans
  build.gradle.kts → merge fail) ni fullBackupContent/dataExtractionRules (conflits merge).
    - meta-data FCM default_notification_icon / _channel_id (= CHANNEL_MESSAGES Kotlin)
  Garde-fou CI : src/lib/mobile/androidFcmManifest.test.ts échoue si ces entrées sautent.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Supprime la permission AD_ID ajoutée automatiquement par Firebase Analytics -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove"/>

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- READ_EXTERNAL_STORAGE n'a plus d'effet depuis API 33 : limité aux API 28-32. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <!-- WRITE_EXTERNAL_STORAGE supprimé : sans effet depuis API 29 (scoped storage obligatoire). -->
    <!-- Accès médias sur Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Notifications push -->
    <uses-permission android:name="com.google.android.c2dm.permission.RECEIVE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- WP-XP-4 : re-enregistrement du token push + drain outbox au boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- AndroidTV support -->
    <uses-feature android:name="android.software.leanback" android:required="false" />

    <application
        android:name=".CanariApplication"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.mines_app"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="${usesCleartextTraffic}"
        android:allowBackup="false"
        tools:replace="android:allowBackup">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:windowSoftInputMode="adjustResize"
            android:launchMode="singleTask"
            android:label="@string/main_activity_title"
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- AndroidTV support -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <!-- DEEP LINK PLUGIN. AUTO-GENERATED. DO NOT REMOVE. -->
            <intent-filter >
                <action android:name="android.intent.action.VIEW" />
                <!-- ChromeOS ARC++ uses a different action for deep links -->
                <action android:name="org.chromium.arc.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="fr.emse.canari" />
                <data android:host="callback" />
                
                
                
                
            </intent-filter>
            <intent-filter >
                <action android:name="android.intent.action.VIEW" />
                <!-- ChromeOS ARC++ uses a different action for deep links -->
                <action android:name="org.chromium.arc.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="fr.emse.canari" />
                <data android:host="stripe" />
                
                
                
                
            </intent-filter>
            <intent-filter >
                <action android:name="android.intent.action.VIEW" />
                <!-- ChromeOS ARC++ uses a different action for deep links -->
                <action android:name="org.chromium.arc.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="fr.emse.canari" />
                <data android:host="chat" />
                
                
                
                
            </intent-filter>
            <intent-filter >
                <action android:name="android.intent.action.VIEW" />
                <!-- ChromeOS ARC++ uses a different action for deep links -->
                <action android:name="org.chromium.arc.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="fr.emse.canari" />
                <data android:host="post" />
                
                
                
                
            </intent-filter>
            <intent-filter >
                <action android:name="android.intent.action.VIEW" />
                <!-- ChromeOS ARC++ uses a different action for deep links -->
                <action android:name="org.chromium.arc.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="fr.emse.canari" />
                <data android:host="form" />
                
                
                
                
            </intent-filter>
            <intent-filter android:autoVerify="true" >
                <action android:name="android.intent.action.VIEW" />
                <!-- ChromeOS ARC++ uses a different action for deep links -->
                <action android:name="org.chromium.arc.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="canari-emse.fr" />




            </intent-filter>
            <!-- DEEP LINK PLUGIN. AUTO-GENERATED. DO NOT REMOVE. -->
        </activity>

        <provider
          android:name="androidx.core.content.FileProvider"
          android:authorities="${applicationId}.fileprovider"
          android:exported="false"
          android:grantUriPermissions="true">
          <meta-data
            android:name="android.support.FILE_PROVIDER_PATHS"
            android:resource="@xml/file_paths" />
        </provider>

        <!-- Réception des messages FCM (push). Sans ce <service> + intent-filter,
             Firebase n'appelle jamais onMessageReceived → aucune notif app tuée. -->
        <service
            android:name=".CanariFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Icône et canal par défaut des notifications FCM -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="canari_messages" />

        <!-- Notification quick actions (WP-XP-1): inline reply / mark as read from the shade. -->
        <receiver
            android:name=".CanariNotificationActionReceiver"
            android:exported="false" />

        <!-- Boot/relaunch re-registration (WP-XP-4) : re-lit le token FCM et draine l'outbox
             au boot / après MAJ de l'app. exported=false suffit : broadcasts protégés émis
             par le système uniquement (même pattern que RescheduleReceiver de WorkManager). -->
        <receiver
            android:name=".CanariBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
