{
  "productName": "Canari",
  "version": "0.5.0",
  "identifier": "fr.emse.canari",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "title": "Canari",
        "width": 800,
        "height": 600,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": [
            "fr.emse.canari"
          ],
          "host": "callback"
        },
        {
          "scheme": [
            "fr.emse.canari"
          ],
          "host": "stripe"
        },
        {
          "scheme": [
            "fr.emse.canari"
          ],
          "host": "chat"
        },
        {
          "scheme": [
            "fr.emse.canari"
          ],
          "host": "post"
        },
        {
          "scheme": [
            "fr.emse.canari"
          ],
          "host": "form"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
