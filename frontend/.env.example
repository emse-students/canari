# ⚠️ Ne jamais commiter de vraies valeurs dans ce fichier.
# Copier vers frontend/.env pour le développement local.
#
# ARCHITECTURE DES SECRETS
# ─────────────────────
# Dev local   : frontend/.env est lu par Vite au démarrage (bun run dev)
# Production  : frontend/.env sur le serveur est IGNORÉ (le build se fait dans
#               le CI GitHub Actions, VITE_JWT_SECRET vient du GitHub Secret JWT_SECRET)

# ── Service URLs ──────────────────────────────────────────────────────────────

# En développement local, ces variables sont OPTIONNELLES.
# Vite proxifie automatiquement :
#   /ws        → ws://localhost:3000  (chat-gateway)
#   /api/mls/* → http://localhost:3010 (chat-delivery-service)
#   /api/chat-delivery-health → http://localhost:3010/api/health (liveness)
# Et le code utilise localhost:3000/3010 comme fallback si la variable est vide.
#
# En production (canari-emse.fr), Nginx route ces chemins sur le même domaine :
#   → laisser vide : le service utilise window.location.origin
VITE_GATEWAY_URL=
# Si le WebSocket échoue en dev alors que chat-gateway tourne : le navigateur envoie
# Origin: http://localhost:1420 — le gateway doit l'accepter (ALLOW_ORIGIN avec cette URL,
# ou *). Voir infrastructure/.env.example (ALLOW_ORIGIN liste séparée par virgules).
VITE_CALL_URL=
VITE_DELIVERY_URL=
VITE_MEDIA_URL=
VITE_SOCIAL_URL=
VITE_CORE_URL=
VITE_MEDIA_MAX_SIZE_MB=50

# ── TURN Server (pour les appels vidéo/audio) ────────────────────────────────
# En dev local, laisser vide pour désactiver le TURN.
# En production, renseigner l'URL du serveur TURN.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# ── Authentik OIDC ────────────────────────────────────────────────────────────
# URL de base de l'instance Authentik (sans slash final)
VITE_AUTHENTIK_URL=https://auth.example.com
# Client ID du Provider OAuth2/OIDC créé dans Authentik
VITE_AUTHENTIK_CLIENT_ID=

# ── Dev Routes ───────────────────────────────────────────────────────────────
# Active l'affichage des raccourcis de dev sur l'UI (ex: login sans Authentik).
# Laisser à false sauf besoin explicite en local.
VITE_ENABLE_DEV_ROUTES=false
