# ⚠️ SECURITY WARNING: NEVER commit real secrets to .env or source code.
# This .env.example shows ALL required variables. Copy to .env locally.

# JWT Secret for development token generation (DEV ONLY, NOT for production)
# ⚠️ CRITICAL: Generate a NEW random value with: openssl rand -hex 32
# Each developer MUST have a unique secret and NEVER share it
VITE_JWT_SECRET=dev_secret_change_me_in_env_file_never_expose

# Production (derrière Nginx qui proxy /ws et /mls-api/ sur le même domaine)
# → laisser vide ou ne pas définir : le service utilise window.location.origin
VITE_GATEWAY_URL=
VITE_HISTORY_URL=

# Développement local (services sur des ports différents)
# Décommenter et adapter :
# VITE_GATEWAY_URL=http://localhost:3000
# VITE_HISTORY_URL=http://localhost:3001
