# ⚠️ Ne jamais commiter de vraies valeurs dans ce fichier.
# Copier vers frontend/.env pour le développement local.
#
# ARCHITECTURE DES SECRETS
# ─────────────────────
# Dev local   : frontend/.env est lu par Vite au démarrage (bun run dev)
# Production  : frontend/.env sur le serveur est IGNORÉ (le build se fait dans
#               le CI GitHub Actions, VITE_JWT_SECRET vient du GitHub Secret JWT_SECRET)

# JWT Secret pour signer les tokens WebSocket (dev local uniquement)
# En production, ce secret est injecté automatiquement par le CI depuis les GitHub Secrets.
# Pour la valeur de dev, lancer : ./scripts/setup-env.sh
VITE_JWT_SECRET=dev_secret_change_me_in_env_file_never_expose

# ── Service URLs ──────────────────────────────────────────────────────────────

# En développement local, ces variables sont OPTIONNELLES.
# Vite proxifie automatiquement :
#   /ws       → ws://localhost:3000  (chat-gateway)
#   /mls-api/ → http://localhost:3010 (chat-delivery-service)
#   /history/ → http://localhost:3010
# Et le code utilise localhost:3000/3010 comme fallback si la variable est vide.
#
# En production (canari-emse.fr), Nginx route ces chemins sur le même domaine :
#   → laisser vide : le service utilise window.location.origin
VITE_GATEWAY_URL=
VITE_HISTORY_URL=
VITE_MEDIA_URL=
VITE_POST_URL=
VITE_MEDIA_MAX_SIZE_MB=50

# Tenor API Key pour le picker GIF (optionnel)
# Obtenir une clé gratuite sur https://developers.google.com/tenor/guides/quickstart
VITE_TENOR_API_KEY=

# Développement local avec URLs explicites (optionnel, le proxy Vite suffit) :
# VITE_GATEWAY_URL=ws://localhost:3000
# VITE_CALL_URL=ws://localhost:3001
# VITE_HISTORY_URL=http://localhost:3010
# VITE_MEDIA_URL=http://localhost:3011
# VITE_USER_URL=http://localhost:3013
# VITE_POST_URL=http://localhost:3015
# VITE_FORM_URL=http://localhost:3016
