# ⚠️ SECURITY WARNING: NEVER commit real secrets to .env or source code.
# This .env.example shows ALL required variables. Copy to .env locally.

# JWT Secret for development token generation (DEV ONLY, NOT for production)
# ⚠️ CRITICAL: This MUST match backend JWT_SECRET for token validation to work!
# Generate with: openssl rand -hex 32
# Each developer MUST have a unique secret and NEVER share it
# Share this value with backend developers or use same .env file
VITE_JWT_SECRET=dev_secret_change_me_in_env_file_never_expose

# ── Service URLs ──────────────────────────────────────────────────────────────

# Production (derrière Nginx qui proxy /ws et /mls-api/ sur le même domaine)
# → laisser vide : le service utilise window.location.origin
# En production sur canari-emse.fr, Nginx route :
#   - /ws → chat-gateway:3000
#   - /mls-api/ → chat-delivery-service:3001
VITE_GATEWAY_URL=
VITE_HISTORY_URL=

# Développement local (services Docker sur ports séparés)
# Décommenter ces lignes pour le développement local :
# VITE_GATEWAY_URL=http://localhost:3000
# VITE_HISTORY_URL=http://localhost:3001
