{
  "name": "mines-app",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "cd .. && husky install frontend/.husky || true",
    "proto:gen": "pbjs -t static-module -w es6 --es6 --no-service --force-number -o src/lib/proto/canari.js ../libs/proto/canari.proto && pbts -o src/lib/proto/canari.d.ts src/lib/proto/canari.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx,.svelte --cache",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx,.svelte --cache --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "date-fns": "^4.1.0",
    "emoji-picker-element": "^1.29.1",
    "lucide-svelte": "^0.577.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.12.0",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.2.6",
    "protobufjs": "^7.5.4",
    "protobufjs-cli": "^2.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1"
  }
}
