    "prettier-plugin-svelte": "^3.5.1",
    "protobufjs": "^8.0.0",
    "protobufjs-cli": "^2.0.0",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
