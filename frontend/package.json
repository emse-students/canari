{
  "name": "canari",
  "version": "0.9.15",
  "private": true,
  "description": "",
  "license": "SEE LICENSE IN ../LICENSE",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "bench:media-crypto": "bun run scripts/bench-image-encryption.ts",
    "prepare": "node ./scripts/install-husky.js && npm run paraglide:compile",
    "proto:gen": "pbjs -t static-module -w es6 --es6 --no-service --force-number -o src/lib/proto/canari.js ../libs/proto/canari.proto && pbts -o src/lib/proto/canari.d.ts src/lib/proto/canari.js && node ./scripts/fix-protobuf-c-alias.mjs",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "check": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:strict": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold warning",
    "check:watch": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint -c .oxlintrc.json src && bash ../scripts/run-oxvelte.sh lint --config oxvelte.config.json src",
    "lint:fix": "oxlint -c .oxlintrc.json --fix src && bash ../scripts/run-oxvelte.sh lint --config oxvelte.config.json --fix src",
    "format": "oxfmt -c ../oxfmt.json --write .",
    "format:check": "oxfmt -c ../oxfmt.json --check .",
    "sync": "svelte-kit sync",
    "tauri": "tauri",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev",
    "android:build": "tauri android build",
    "ios:init": "tauri ios init",
    "ios:dev": "tauri ios dev",
    "ios:build": "tauri ios build"
  },
  "dependencies": {
    "@fontsource-variable/fredoka": "^5.2.10",
    "@fontsource-variable/nunito": "^5.2.7",
    "@humanspeak/svelte-markdown": "^1.6.0",
    "@impierce/tauri-plugin-keystore": "^2.1.0-alpha.1",
    "@lucide/svelte": "^1.21.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-biometric": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-websocket": "^2.4.2",
    "emoji-picker-element": "^1.29.1",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.20.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^25.9.4",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "protobufjs": "^8.6.4",
    "protobufjs-cli": "^2.5.5",
    "sharp": "^0.34.5",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "cookie": "^0.7.0",
    "postcss": "^8.5.10"
  }
}
