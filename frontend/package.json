{
  "name": "canari",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "node ./scripts/install-husky.js",
    "proto:gen": "pbjs -t static-module -w es6 --es6 --no-service --force-number -o src/lib/proto/canari.js ../libs/proto/canari.proto && pbts -o src/lib/proto/canari.d.ts src/lib/proto/canari.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx,.svelte --cache",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx,.svelte --cache --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync": "svelte-kit sync",
    "tauri": "tauri",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev",
    "android:build": "tauri android build"
  },
  "license": "MIT",
  "dependencies": {
    "@impierce/tauri-plugin-keystore": "^2.1.0-alpha.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-biometric": "^2.3.2",
    "@tauri-apps/plugin-http": "~2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "date-fns": "^4.1.0",
    "emoji-picker-element": "^1.29.1",
    "jsqr": "^1.4.0",
    "lucide-svelte": "^1.0.1",
    "qrcode": "^1.5.4",
    "svelte-markdown": "^0.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
