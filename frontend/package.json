{
  "name": "canari",
  "version": "0.6.3",
  "description": "",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "bench:media-crypto": "bun run scripts/bench-image-encryption.ts",
    "prepare": "node ./scripts/install-husky.js",
    "proto:gen": "pbjs -t static-module -w es6 --es6 --no-service --force-number -o src/lib/proto/canari.js ../libs/proto/canari.proto && pbts -o src/lib/proto/canari.d.ts src/lib/proto/canari.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:strict": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold warning",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx,.svelte --cache",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx,.svelte --cache --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync": "svelte-kit sync",
    "tauri": "tauri",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev",
    "android:build": "tauri android build"
  },
  "license": "MIT",
