{
  "name": "social-service",
  "version": "0.9.19",
  "private": true,
  "scripts": {
    "start": "ts-node src/main.ts",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --runInBand --testRegex .*\\.e2e-spec\\.ts$",
    "smoke": "node scripts/smoke-test.mjs",
    "lint": "oxlint -c ../../.oxlintrc.nest.json src test",
    "lint:fix": "oxlint -c ../../.oxlintrc.nest.json --fix src test",
    "format": "oxfmt -c ../../oxfmt.json --write \"src/**/*.ts\"",
    "format:check": "oxfmt -c ../../oxfmt.json --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/typeorm": "^11.0.3",
    "axios": "^1.18.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.6",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.6.0",
    "jest": "^30.2.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "qs": "6.15.2",
    "tmp": "0.2.7",
    "brace-expansion": "^5.0.6",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6",
    "multer": "^2.2.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
