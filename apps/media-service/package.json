{
  "name": "media-service",
  "version": "0.10.3",
  "scripts": {
    "start": "ts-node src/main.ts",
    "start:dev": "nest start --watch",
    "test": "jest --passWithNoTests",
    "lint": "oxlint -c ../../.oxlintrc.nest.json src test",
    "lint:fix": "oxlint -c ../../.oxlintrc.nest.json --fix src test",
    "format": "oxfmt -c ../../oxfmt.json --write \"src/**/*.ts\"",
    "format:check": "oxfmt -c ../../oxfmt.json --check \"src/**/*.ts\"",
    "build": "nest build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fs-extra": "^11.3.6",
    "minio": "^8.0.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/uuid": "^10.0.0",
    "jest": "^30.2.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^7.0.2001",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "qs": "6.15.2",
    "brace-expansion": "^5.0.6",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6",
    "multer": "^2.2.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
