# Application Port
PORT=3006

# MongoDB Connection String
POSTS_MONGO_URI=mongodb://localhost:27017/post_db

# Stripe Configuration (Optional)
# Required only if you want to test paid event registration.
# Obtain keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_SUCCESS_URL=http://localhost:5173/posts?registration=success
STRIPE_CANCEL_URL=http://localhost:5173/posts?registration=cancel
